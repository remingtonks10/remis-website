# Authorize.Net merchant credentials
AUTHORIZE_NET_API_LOGIN_ID=
AUTHORIZE_NET_TRANSACTION_KEY=

# Use sandbox for testing, production for live payments
AUTHORIZE_NET_ENVIRONMENT=sandbox

# Webhook verification (recommended)
AUTHORIZE_NET_WEBHOOK_SIGNATURE_KEY=
AUTHORIZE_NET_WEBHOOK_ID=

# ClickSend text list opt-in
# Keep these server-side only. Do not expose them with NEXT_PUBLIC_ prefixes.
CLICKSEND_USERNAME=
CLICKSEND_API_KEY=
CLICKSEND_BAGGED_PICKUP_LIST_ID=
CLICKSEND_FEED_DELIVERY_LIST_ID=
